# =============================================================================
# bcvnas-converter 設定範本
# 複製此檔案為 .env 並填入實際值：cp .env.sample .env
# =============================================================================

# -----------------------------------------------------------------------------
# 資料庫設定（MariaDB / MySQL）
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=video_converter

# -----------------------------------------------------------------------------
# 轉檔設定
# -----------------------------------------------------------------------------
# 同時執行的 ffmpeg 工作數量
MAX_WORKERS=1

# 只轉檔短邊解析度高於此值的影片（預設 361，即 720p 以上）
MIN_RESOLUTION=361

# 支援的影片副檔名（逗號分隔）
SUPPORTED_EXTENSIONS=.mp4,.mkv,.mts,.mxf,.mpg,.avi,.mov

# -----------------------------------------------------------------------------
# 目錄設定
# -----------------------------------------------------------------------------
# 原始影片輸入目錄（必填）
INPUT_DIRECTORY=/path/to/input/videos

# 轉檔後輸出目錄（必填）
OUTPUT_DIRECTORY=/path/to/output/videos

# 掃描時要忽略的目錄（逗號分隔，支援絕對路徑或相對路徑）
# 輸出目錄建議一律加入，避免重複掃描已轉好的檔案
IGNORE_DIRECTORIES=/path/to/output/videos,@Recycle,temp,cache,.git

# 是否明確排除輸出目錄（建議保持 true）
IGNORE_OUTPUT_DIR=true

# -----------------------------------------------------------------------------
# 輸出檔長度驗證
# -----------------------------------------------------------------------------
# 掃描時比對輸出檔與原始檔的時長差異（單位：秒）
# 差異超過此值則視為不完整，自動刪除輸出檔並重新加入轉檔佇列
# 設為 0 可停用驗證（只要輸出檔存在即略過）
DURATION_THRESHOLD=2.0

# -----------------------------------------------------------------------------
# 時間限制設定
# -----------------------------------------------------------------------------
# 是否僅在指定時段執行轉檔（例如：離峰時段）
ENABLE_TIME_RESTRICTION=false

# 允許開始轉檔的時間（24 小時制，ENABLE_TIME_RESTRICTION=true 時生效）
ALLOWED_START_TIME=22:00

# 允許結束轉檔的時間（24 小時制，可跨午夜）
ALLOWED_END_TIME=06:00

# 處理 daemon 主迴圈的檢查間隔（秒）
CHECK_INTERVAL=300

# -----------------------------------------------------------------------------
# 重試與清理設定
# -----------------------------------------------------------------------------
# 失敗任務最大重試次數
MAX_RETRIES=3

# 每幾個 check cycle 執行一次重試（預設 10 次 ≈ 50 分鐘）
RETRY_INTERVAL_CYCLES=10

# 任務卡在 processing 超過幾小時則視為過時並自動清理
STALE_HOURS=4

# -----------------------------------------------------------------------------
# API Server 設定
# -----------------------------------------------------------------------------
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=43689
API_SERVER_LOG_FILE=./log/api.log
API_SERVER_ERROR_LOG_FILE=./log/api_error.log
API_SERVER_STATUS_DIR=./run

# 供 main.py 等工具呼叫 API 用
API_SERVER_URL=http://localhost:43689

# -----------------------------------------------------------------------------
# Scan Daemon 設定
# -----------------------------------------------------------------------------
SCAN_DAEMON_PID_FILE=./run/scanner.pid
SCAN_DAEMON_LOG_FILE=./log/scanner.log
SCAN_DAEMON_ERROR_LOG_FILE=./log/scanner_error.log
SCAN_DAEMON_STATUS_FILE=./run/scanner_status.json
SCAN_DAEMON_STATUS_UPDATE_INTERVAL=10

# -----------------------------------------------------------------------------
# Process Daemon 設定
# -----------------------------------------------------------------------------
PROCESS_DAEMON_PID_FILE=./run/processor.pid
PROCESS_DAEMON_LOG_FILE=./log/processor.log
PROCESS_DAEMON_ERROR_LOG_FILE=./log/processor_error.log
PROCESS_DAEMON_STATUS_FILE=./run/processor_status.json
PROCESS_DAEMON_STATUS_UPDATE_INTERVAL=10

# -----------------------------------------------------------------------------
# 日誌與執行期目錄
# -----------------------------------------------------------------------------
VIDEO_CONVERTER_LOG_DIR=./log
VIDEO_CONVERTER_RUN_DIR=./run
